generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  password     String
  profilePhoto String?
  bio          String?
  lastSeen     DateTime @default(now())
  isOnline     Boolean  @default(false)
  messageTone  String   @default("message")
  ringtone     String   @default("call")
  pushEnabled  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions         Session[]
  sentRequests     FriendRequest[]      @relation("SentRequests")
  receivedRequests FriendRequest[]      @relation("ReceivedRequests")
  friendshipsUser1 Friendship[]         @relation("FriendshipsUser1")
  friendshipsUser2 Friendship[]         @relation("FriendshipsUser2")
  memberships      ConversationMember[]
  messages         Message[]
  seenMessages     MessageSeen[]
  reactions        MessageReaction[]
  callerCalls      CallHistory[]        @relation("CallerCalls")
  receiverCalls    CallHistory[]        @relation("ReceiverCalls")
  notifications    Notification[]
  blockedUsers     BlockedUser[]        @relation("BlockedUsers")
  blockedBy        BlockedUser[]        @relation("BlockedBy")
  pushSubscriptions PushSubscription[]
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  refreshToken String   @unique
  deviceInfo   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum RequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model FriendRequest {
  id         String        @id @default(uuid())
  senderId   String
  receiverId String
  status     RequestStatus @default(PENDING)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  sender   User @relation("SentRequests", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedRequests", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([senderId])
  @@index([receiverId])
}

model Friendship {
  id        String   @id @default(uuid())
  user1Id   String
  user2Id   String
  createdAt DateTime @default(now())

  user1 User @relation("FriendshipsUser1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2 User @relation("FriendshipsUser2", fields: [user2Id], references: [id], onDelete: Cascade)

  @@unique([user1Id, user2Id])
  @@index([user1Id])
  @@index([user2Id])
}

model BlockedUser {
  id        String   @id @default(uuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker   User @relation("BlockedUsers", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   User @relation("BlockedBy", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

model Conversation {
  id        String   @id @default(uuid())
  isGroup   Boolean  @default(false)
  name      String? // For group chats
  avatar    String? // For group chats
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members  ConversationMember[]
  messages Message[]

  @@index([updatedAt])
}

enum Role {
  ADMIN
  MEMBER
}

model ConversationMember {
  id             String   @id @default(uuid())
  userId         String
  conversationId String
  role           Role     @default(MEMBER)
  joinedAt       DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([userId, conversationId])
  @@index([userId])
  @@index([conversationId])
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  VOICE
  DOCUMENT
  SYSTEM
}

model Message {
  id             String      @id @default(uuid())
  conversationId String
  senderId       String
  content        String?
  type           MessageType @default(TEXT)
  isDeleted      Boolean     @default(false)
  replyToId      String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  replyTo      Message?     @relation("ReplyTo", fields: [replyToId], references: [id], onDelete: SetNull)
  replies      Message[]    @relation("ReplyTo")

  attachments Attachment[]
  seenBy      MessageSeen[]
  reactions   MessageReaction[]

  @@index([conversationId, createdAt(sort: Desc)])
  @@index([senderId])
}

model Attachment {
  id        String   @id @default(uuid())
  messageId String
  url       String
  publicId  String? // For Cloudinary
  type      String // MIME type
  size      Int? // bytes
  name      String?
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}

model MessageSeen {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  seenAt    DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([messageId])
  @@index([userId])
}

model MessageReaction {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

enum CallStatus {
  MISSED
  ANSWERED
  REJECTED
  ONGOING
}

model CallHistory {
  id         String     @id @default(uuid())
  callerId   String
  receiverId String
  status     CallStatus
  startedAt  DateTime   @default(now())
  endedAt    DateTime?
  duration   Int? // in seconds
  isVideo    Boolean    @default(false)

  caller   User @relation("CallerCalls", fields: [callerId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceiverCalls", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([callerId])
  @@index([receiverId])
}

enum NotificationType {
  FRIEND_REQUEST
  MESSAGE
  CALL
  SYSTEM
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  content   String
  isRead    Boolean          @default(false)
  entityId  String? // e.g. friend request id, message id
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
